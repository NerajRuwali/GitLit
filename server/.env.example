# GitHub Personal Access Token (required for higher rate limits)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Server port (Render sets PORT automatically)
PORT=5001

# Frontend URL (for CORS — production Vercel domain)
FRONTEND_URL=https://git-lit.vercel.app

# Node environment
NODE_ENV=production

# OpenAI API Key (optional — for AI Insights feature)
OPENAI_API_KEY=your_openai_key_here
